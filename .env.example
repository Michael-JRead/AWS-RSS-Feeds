# AWS RSS Digest — environment variable template
# Copy this file to .env and fill in your values (optional).
# The app primarily uses config.json for settings (configured via the UI).
# These env vars are only needed if you prefer not to store credentials in config.json.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_TLS=true
